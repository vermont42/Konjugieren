    "AblautGroupInfo.beginnen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das i→a→o-Muster: $begInnen$ → $begAnn$ → $begOnnen$. Verwandt mit gewinnen und gelingen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The i→a→o pattern: $begInnen$ → $begAnn$ → $begOnnen$. Related to gewinnen and gelingen."
          }
        }
      }
    },
    "AblautGroupInfo.bieten": {
