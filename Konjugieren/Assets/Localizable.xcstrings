    "Onboarding.exploreFamiliesButton": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Familien erkunden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore Families"
          }
        }
      }
    },
    "Onboarding.familiesBody": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entdecke die vier Verbfamilien вҖ“ stark, schwach, gemischt und -ieren вҖ“ jede mit eigenen Konjugationsmustern. Das Verstehen der Familien hilft dir, das Verhalten unbekannter Verben vorherzusagen. Erfahre, wie sich trennbare und untrennbare Verben in verschiedenen Conjugationgroups verhalten. Nutze das Wissen Гјber PrГӨfixbedeutung und Etymologie, um die Bedeutung unbekannter Verben zu erraten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover the four verb familiesвҖ”strong, weak, mixed, and -ierenвҖ”each with distinct conjugation patterns. Understanding families helps you predict how unfamiliar verbs behave. Learn how separable and inseparable verbs behave across conjugationgroups. Use knowledge of prefix meaning and etymology to guess meanings of unfamiliar verbs."
          }
        }
      }
    },
    "Onboarding.familiesTitle": {
      "localizations": {
