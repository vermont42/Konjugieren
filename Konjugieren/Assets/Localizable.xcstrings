    "Onboarding.learnBody": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lies umfassende Abhandlungen Гјber vierzehn deutsche Conjugationgroups, mit Beispielen von Goethe, Kafka und Mann, sowie eine 5.000-jГӨhrige Geschichte des deutschen Verbs."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read comprehensive treatises on fourteen German conjugation groups, with examples from Goethe, Kafka, and Mann, plus a 5,000-year history of the German verb."
          }
        }
      }
    },
