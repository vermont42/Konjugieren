    "Onboarding.quizBody": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mach zeitgesteuerte Quizze, sammle Punkte und tritt auf der Game-Center-Rangliste an. Wähle zwischen normaler und lächerlicher Schwierigkeit. Letztere enthält Conjugationgroups, die außerhalb formeller oder akademischer Texte selten vorkommen. Die Belohnung für die lächerliche Schwierigkeit ist großartig: doppelte Punktzahl."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take timed quizzes, earn points, and compete on the Game Center leaderboard. Choose regular or ridiculous difficulty. The latter includes conjugationgroups that are rarely seen outside formal or academic writing. The reward for ridiculous difficulty is great: double the score."
          }
        }
      }
    },
