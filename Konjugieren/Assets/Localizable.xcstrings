    "Onboarding.browseBody": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erkunde 988 starke, schwache, gemischte und -ieren-Verben. Tippe auf ein Verb, um die vollstГӨndige Konjugationstabelle mit hervorgehobenen AblautГӨnderungen und anderen UnregelmГӨГҹigkeiten zu sehen. Sortiere Verben nach GebrauchshГӨufigkeit zum Lernen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore 988 strong, weak, mixed, and -ieren verbs. Tap any verb to see its full conjugation table with ablaut changes and other irregularities highlighted. Sort verbs by frequency of use for study purposes."
          }
        }
      }
    },
    "Onboarding.browseTitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "988 deutsche Verben durchstГ¶bern"
          }
