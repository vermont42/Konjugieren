    "Settings.conjugationgroupLangDescription": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Einstellung legt fest, ob in der Benutzeroberfläche von Konjugieren die tatsächlichen deutschen Conjugationgroupnamen oder deren englische Entsprechungen angezeigt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This setting determines whether actual German conjugationgroup names or their English equivalents are shown in Konjugieren’s user interface. "
