          "stringUnit": {
            "state": "translated",
            "value": "Verbs"
          }
        }
      }
    },
    "FamilyDetail.weakLong": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "~Schwache~ Verben bilden die groГҹe Mehrheit der deutschen Verben und stehen fГјr das вҖһregelmГӨГҹigeвҖң Konjugationsmuster. Sie zeigen die Vergangenheit durch das Suffix ~-te~ am Stamm an: ~machen~ вҶ’ ~machte~. Das ~Perfektpartizip~ verwendet ~ge-~ plus ~-t~: ~gemacht~.\n\nDieses Muster entstand im Proto-Germanischen und erwies sich als so produktiv, dass fast alle neuen Verben im Deutschen zu schwachen Verben werden: ~googeln~ вҶ’ ~googelte~, ~gegoogelt~.\n\nEnglische schwache Verben funktionieren identisch mit ~-ed~: ~walk~ вҶ’ ~walked~, ~walked~. Die germanischen Sprachen entwickelten dieses Muster um 500 v. Chr., mГ¶glicherweise durch Verwendung einer Form von вҖһtunвҖң als Hilfsverb, das schlieГҹlich mit dem Verbstamm verschmolz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "~Weak~ verbs form the vast majority of German verbs and represent the \"regular\" conjugation pattern. They signal past tense by adding a ~-te~ suffix to the stem: ~machen~ вҶ’ ~machte~. The ~Perfektpartizip~ uses ~ge-~ plus ~-t~: ~gemacht~.\n\nThis pattern emerged in Proto-Germanic and proved so productive that nearly all new verbs entering German become weak verbs: ~googeln~ вҶ’ ~googelte~, ~gegoogelt~.\n\nEnglish weak verbs work identically with ~-ed~: ~walk~ вҶ’ ~walked~, ~walked~. The Germanic languages developed this pattern around 500 BCE, possibly by using a form of \"do\" as an auxiliary that eventually fused with the verb stem."
          }
        }
      }
    },
