        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das ie→o-Muster: $bIEten$ → $bOt$ → $gebOten$. Geteilt von fliegen, schließen, verlieren und weiteren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The ie→o pattern: $bIEten$ → $bOt$ → $gebOten$. Shared by fliegen, schließen, verlieren, and more."
          }
        }
      }
    },
    "AblautGroupInfo.bitten": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vokal- und Konsonantenwechsel: $bITTen$ → $bAT$ → $gebETen$. Das verdoppelte -tt- verkürzt sich in Vergangenheitskonjugationen."
          }
