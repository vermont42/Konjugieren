    "Settings.quizDifficultyDescription": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Einstellung bestimmt die Schwierigkeit der Quizze. Normalerweise ist Regulär empfohlen, da Lächerlich Conjugationgroups enthält, die nicht weit verbreitet sind."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This setting determines the difficulty of quizzes. You probably want Regular because Ridiculous includes conjugationgroups that are not in widespread use."
          }
        }
      }
    },
    "Settings.quizDifficultyHeading": {
