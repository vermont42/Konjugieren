    "Onboarding.exploreFamiliesButton": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Familien erkunden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore Families"
          }
        }
      }
    },
    "Onboarding.familiesBody": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entdecke die vier Verbfamilien – stark, schwach, gemischt und -ieren – jede mit eigenen Konjugationsmustern. Das Verstehen der Familien hilft dir, das Verhalten unbekannter Verben vorherzusagen. Erfahre, wie sich trennbare und untrennbare Verben in verschiedenen Conjugationgroups verhalten. Nutze das Wissen über Präfixbedeutung und Etymologie, um die Bedeutung unbekannter Verben zu erraten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover the four verb families—strong, weak, mixed, and -ieren—each with distinct conjugation patterns. Understanding families helps you predict how unfamiliar verbs behave. Learn how separable and inseparable verbs behave across conjugationgroups. Use knowledge of prefix meaning and etymology to guess meanings of unfamiliar verbs."
          }
        }
      }
    },
    "Onboarding.familiesTitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbfamilien erkunden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore Verb Families"
          }
        }
      }
    },
