    "Onboarding.quizBody": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mach zeitgesteuerte Quizze, sammle Punkte und tritt auf der Game-Center-Rangliste an. WГӨhle zwischen normaler und lГӨcherlicher Schwierigkeit. Letztere enthГӨlt Conjugationgroups, die auГҹerhalb formeller oder akademischer Texte selten vorkommen. Die Belohnung fГјr die lГӨcherliche Schwierigkeit ist groГҹartig: doppelte Punktzahl."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take timed quizzes, earn points, and compete on the Game Center leaderboard. Choose regular or ridiculous difficulty. The latter includes conjugationgroups that are rarely seen outside formal or academic writing. The reward for ridiculous difficulty is great: double the score."
          }
        }
      }
    },
