            "state": "translated",
            "value": "Wie fahren: a→ä→u-Muster. $schlAgen$ → $schlÄgst$ → $schlUg$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like fahren: a→ä→u pattern. $schlAgen$ → $schlÄgst$ → $schlUg$."
          }
        }
      }
    },
    "AblautGroupInfo.schließen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie bieten: ie→o-Muster. $schlIEßen$ → $schlOss$ → $geschlOssen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like bieten: ie→o pattern. $schlIEßen$ → $schlOss$ → $geschlOssen$."
          }
        }
      }
    },
    "AblautGroupInfo.schneiden": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie leiden: eid→itt. $schnEIDen$ → $schnITT$ → $geschnITTen$. Konsonant verdoppelt sich im Präteritum."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like leiden: eid→itt. $schnEIDen$ → $schnITT$ → $geschnITTen$. Consonant doubles in past."
          }
        }
      }
    },
    "AblautGroupInfo.schreien": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrahiertes Partizip: $schrEIen$ → $schrIE$ → $geschrIEn$. Das -en kontrahiert zu -n."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Contracted participle: $schrEIen$ → $schrIE$ → $geschrIEn$. The -en contracts to -n."
          }
        }
      }
    },
    "AblautGroupInfo.schreiten": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie schneiden: eit→itt. $schrEITen$ → $schrITT$ → $geschrITTen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like schneiden: eit→itt. $schrEITen$ → $schrITT$ → $geschrITTen$."
          }
        }
      }
    },
    "AblautGroupInfo.sehen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie geben: e→ie (Präsens 2s/3s), e→a (Präteritum). $sIEht$, $sAh$, $gesEhen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like geben: e→ie (Präsens 2s/3s), e→a (Präteritum). $sIEht$, $sAh$, $gesEhen$."
          }
        }
      }
    },
    "AblautGroupInfo.sein": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Suppletivverb schlechthin. Vereint zwei urgermanische Wurzeln: *beuną (→$BIN$, $BIst$, $Ist$) und *wesaną (→sein, $WAR$, $geWEsen$)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The ultimate suppletive verb. Combines two Proto-Germanic roots: *beuną (→$BIN$, $BIst$, $Ist$) and *wesaną (→sein, $WAR$, $geWEsen$)."
          }
        }
      }
    },
    "AblautGroupInfo.singen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die klassische i→a→u-Reihe: $sIngen$ → $sAng$ → $gesUngen$. Das englische \"sing, sang, sung\" ist nahezu identisch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The classic i→a→u series: $sIngen$ → $sAng$ → $gesUngen$. English \"sing, sang, sung\" is nearly identical."
          }
        }
      }
    },
    "AblautGroupInfo.sitzen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das i→a→e-Muster: $sItzen$ → $sAß$ → $gesEssen$. Verwandt mit dem englischen \"sit, sat\"."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The i→a→e pattern: $sItzen$ → $sAß$ → $gesEssen$. Related to English \"sit, sat\"."
          }
        }
      }
    },
    "AblautGroupInfo.sprechen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klassisches Muster: e→i (Präsens 2s/3s), e→a (Präteritum), e→o (Perfektpartizip). $sprIcht$, $sprAch$, $gesprOchen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Classic pattern: e→i (Präsens 2s/3s), e→a (Präteritum), e→o (Perfektpartizip). $sprIcht$, $sprAch$, $gesprOchen$."
          }
        }
      }
    },
    "AblautGroupInfo.stehen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Suppletiv-artig: $stEHen$ → $stAND$ → $gestANDen$. Die Vergangenheitsformen verwenden eine andere Wurzel."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Suppletive-like: $stEHen$ → $stAND$ → $gestANDen$. The past-tense conjugations use a different root."
          }
        }
      }
    },
    "AblautGroupInfo.steigen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie bleiben: ei→ie durchgehend. $stEIgen$ → $stIEg$ → $gestIEgen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like bleiben: ei→ie throughout. $stEIgen$ → $stIEg$ → $gestIEgen$."
          }
        }
      }
    },
    "AblautGroupInfo.sterben": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie sprechen: e→i (Präsens 2s/3s), e→a (Präteritum), e→o (Perfektpartizip). $stIrbt$, $stArb$, $gestOrben$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like sprechen: e→i (Präsens 2s/3s), e→a (Präteritum), e→o (Perfektpartizip). $stIrbt$, $stArb$, $gestOrben$."
          }
        }
      }
    },
    "AblautGroupInfo.stoßen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Umlaut plus ie: $stOßen$ → $stÖßt$ → $stIEß$. Wie halten und lassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Umlaut plus ie: $stOßen$ → $stÖßt$ → $stIEß$. Like halten and lassen."
          }
        }
      }
    },
    "AblautGroupInfo.streichen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie greifen: ei→i mit Konsonant. $strEICHen$ → $strICH$ → $gestrICHen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like greifen: ei→i with consonant. $strEICHen$ → $strICH$ → $gestrICHen$."
          }
        }
      }
    },
    "AblautGroupInfo.tragen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie fahren: a→ä→u-Muster. $trAgen$ → $trÄgst$ → $trUg$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like fahren: a→ä→u pattern. $trAgen$ → $trÄgst$ → $trUg$."
          }
        }
      }
    },
    "AblautGroupInfo.treffen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Komplexe Konsonanten: $trEFFen$ → $trIFFt$ → $trAF$ → $getrOFFen$. Das -ff- ändert sich durchgehend."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Complex consonants: $trEFFen$ → $trIFFt$ → $trAF$ → $getrOFFen$. The -ff- changes throughout."
          }
        }
      }
    },
    "AblautGroupInfo.treten": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie bitten: Vokal- und Konsonantenwechsel. $trETen$ → $trITTst$ → $trAT$ → $geTRETen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like bitten: vowel plus consonant. $trETen$ → $trITTst$ → $trAT$ → $geTRETen$."
          }
        }
      }
    },
    "AblautGroupInfo.tun": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hochgradig unregelmäßig: $tUn$ → $tAT$ → $getAn$. Eines der ältesten deutschen Verben mit einzigartiger Konjugation."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Highly irregular: $tUn$ → $tAT$ → $getAn$. One of German's oldest verbs with unique conjugation."
          }
        }
      }
    },
    "AblautGroupInfo.verlieren": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie bieten: ie→o-Muster. $verlIEren$ → $verlOr$ → $verlOren$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like bieten: ie→o pattern. $verlIEren$ → $verlOr$ → $verlOren$."
          }
        }
      }
    },
    "AblautGroupInfo.wachsen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie fahren: a→ä→u-Muster. $wAchsen$ → $wÄchst$ → $wUchs$. Verwendet sein als Hilfsverb."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like fahren: a→ä→u pattern. $wAchsen$ → $wÄchst$ → $wUchs$. Uses sein as auxiliary."
          }
        }
      }
    },
    "AblautGroupInfo.weisen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie bleiben: ei→ie durchgehend. $wEIsen$ → $wIEs$ → $gewIEsen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like bleiben: ei→ie throughout. $wEIsen$ → $wIEs$ → $gewIEsen$."
          }
        }
      }
    },
    "AblautGroupInfo.werden": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unverzichtbares Hilfsverb: $wIrst$, $wIrD$ (Präsens), $wUrde$ (Präteritum), $gewOrden$. Verwendet für Futur und Passiv."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Essential auxiliary: $wIrst$, $wIrD$ (Präsens), $wUrde$ (Präteritum), $gewOrden$. Used for future and passive."
          }
        }
      }
    },
    "AblautGroupInfo.werfen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie sprechen: e→i (Präsens 2s/3s), e→a (Präteritum), e→o (Perfektpartizip). $wIrft$, $wArf$, $gewOrfen$."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Like sprechen: e→i (Präsens 2s/3s), e→a (Präteritum), e→o (Perfektpartizip). $wIrft$, $wArf$, $gewOrfen$."
          }
        }
      }
    },
    "AblautGroupInfo.wissen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modalverb-artiges Verb: $wEIß$, $wEIßt$ (Präsens), $wUsste$ (Präteritum). Unregelmäßiges Präsens Singular."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Modal-like verb: $wEIß$, $wEIßt$ (Präsens), $wUsste$ (Präteritum). Irregular singular present."
          }
        }
      }
    },
    "AblautGroupInfo.wollen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modalverb: $wIlL$, $wIllst$ (Präsens). Unregelmäßiges Präsens Singular, regelmäßiges Präteritum."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Modal verb: $wIlL$, $wIllst$ (Präsens). Irregular singular present, regular past."
          }
        }
      }
    },
    "AblautGroupInfo.ziehen": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konsonantenwechsel: $zIEHen$ → $zOG$ → $gezOGen$. Das -h- wird in Vergangenheitskonjugationen zu -g-."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Consonant change: $zIEHen$ → $zOG$ → $gezOGen$. The -h- becomes -g- in past-tense conjugations."
